venv/
env/
.venv/

# Кеш байт-коду Python
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 3. MARIMO ТА АРТЕФАКТИ ЗБІРКИ (ДЛЯ LMS)
# ==========================================
